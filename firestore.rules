rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check auth
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Users: Users can read/write their own data
    match /users/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
      
      // Allow reading/writing subcollections (like quiz_results)
      match /{document=**} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }
    }

    // Learning Materials: Users can read their own uploads
    match /learning_materials/{docId} {
      allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Quizzes: Readable by anyone (or restrict if needed), writable by AI Service (client for now)
    match /quizzes/{quizId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated(); // In production, this might be restricted to Admin SDK/Cloud Functions
    }

    // Chats: Private to user
    match /chats/{userId}/{document=**} {
        allow read, write: if isAuthenticated() && isOwner(userId);
    }
    
    // Activity Logs: Write only for user
    match /activity_logs/{logId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // Reviews: Public read, Authenticated create
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated();
    }
  }
}
